<UserControl
    x:Class="Chat.App.Wpf.Views.Dialogs.ConfirmationDialogView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Chat.App.Wpf.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dialogViewModels="clr-namespace:Chat.App.Wpf.ViewModels.DialogViewModels"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type=dialogViewModels:ConfirmationDialogViewModel,
                                     IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <materialDesign:Card Style="{StaticResource ChatDialogCardStyle}">
        <StackPanel>
            <TextBlock Style="{StaticResource ChatTitleTextStyle}" Text="{Binding Title}" />
            <TextBlock Style="{StaticResource ChatSubtitleTextStyle}" Text="{Binding Message}" />

            <controls:DialogButtonPanel
                CancelCommand="{Binding CancelDialogCommand}"
                CancelText="{Binding CancelText}"
                ConfirmCommand="{Binding ConfirmCommand}"
                ConfirmText="{Binding ConfirmText}" />
        </StackPanel>
    </materialDesign:Card>
</UserControl>
