<UserControl
    x:Class="Chat.App.Wpf.Views.RegisterView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:loc="clr-namespace:Chat.App.Wpf.Localization"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:Chat.App.Wpf.ViewModels"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=viewModels:RegisterViewModel, IsDesignTimeCreatable=False}">
    <Grid Background="{StaticResource ChatWindowBackgroundBrush}">

        <Border
            Width="{StaticResource ChatFormWidth}"
            Margin="{StaticResource ChatPageMargin}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Style="{StaticResource ChatSurfaceBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <ProgressBar
                    Grid.Row="0"
                    Height="4"
                    Margin="0,0,0,18"
                    IsIndeterminate="True"
                    Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibility}}" />

                <StackPanel Grid.Row="1" Margin="0,0,0,16">
                    <TextBlock Style="{StaticResource ChatHeadlineTextStyle}" Text="{loc:Loc Register_Title}" />
                </StackPanel>

                <StackPanel Grid.Row="2" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolean}}">
                    <TextBox
                        materialDesign:HintAssist.Hint="{loc:Loc Register_Username}"
                        materialDesign:TextFieldAssist.HasClearButton="True"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="AccountCircle"
                        Style="{StaticResource ChatOutlinedTextBoxStyle}"
                        Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />

                    <PasswordBox
                        x:Name="PasswordInput"
                        PasswordChanged="PasswordInput_OnPasswordChanged"
                        materialDesign:HintAssist.Hint="{loc:Loc Register_Password}"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="Lock"
                        Style="{StaticResource ChatOutlinedPasswordBoxStyle}" />

                    <TextBlock
                        Style="{StaticResource ChatErrorTextStyle}"
                        Text="{Binding ErrorMessage}"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyToVisibility}}" />

                    <Button
                        Command="{Binding RegisterCommand}"
                        IsDefault="True"
                        Style="{StaticResource ChatPrimaryButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="20"
                                Height="20"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                Kind="AccountPlus" />
                            <TextBlock VerticalAlignment="Center" Text="{loc:Loc Register_Submit}" />
                        </StackPanel>
                    </Button>

                    <TextBlock
                        Margin="0,18,0,0"
                        HorizontalAlignment="Center"
                        Style="{StaticResource ChatMetaTextStyle}">
                        <Hyperlink Command="{Binding GoToLoginCommand}" Style="{StaticResource ChatInlineHyperlinkStyle}">
                            <Run Text="{loc:Loc Register_HaveAccount}" />
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
