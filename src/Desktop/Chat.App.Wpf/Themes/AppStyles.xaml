<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:system="clr-namespace:System;assembly=System.Runtime">

    <!--  Layout  -->
    <system:Double x:Key="ChatFormWidth">420</system:Double>
    <system:Double x:Key="ChatDialogWidth">460</system:Double>
    <system:Double x:Key="ChatMessageMaxWidth">560</system:Double>
    <system:Double x:Key="ChatAvatarSize">44</system:Double>
    <Thickness x:Key="ChatPageMargin">28</Thickness>
    <Thickness x:Key="ChatCardPadding">28</Thickness>

    <!--  Every corner in the app shares this single value.  -->
    <CornerRadius x:Key="ChatCornerRadius">6</CornerRadius>

    <SolidColorBrush x:Key="ChatWindowBackgroundBrush" Color="#FFF3F5F7" />

    <!--  Facebook blue  -->
    <SolidColorBrush x:Key="ChatPrimaryBrush" Color="#FF1877F2" />
    <SolidColorBrush x:Key="ChatPrimaryDarkBrush" Color="#FF0C5DC7" />
    <SolidColorBrush x:Key="ChatPrimarySoftBrush" Color="#FFE7F0FE" />
    <SolidColorBrush x:Key="ChatAccentBrush" Color="#FFD97904" />
    <SolidColorBrush x:Key="ChatAccentSoftBrush" Color="#FFFFF0D9" />
    <SolidColorBrush x:Key="ChatPanelBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="ChatPanelAltBrush" Color="#FFF7FAFC" />
    <SolidColorBrush x:Key="ChatPanelStrongBrush" Color="#FFF1F6F8" />
    <SolidColorBrush x:Key="ChatBorderBrush" Color="#FFD6E0E6" />
    <SolidColorBrush x:Key="ChatBorderStrongBrush" Color="#FFC4D1D8" />
    <SolidColorBrush x:Key="ChatInkBrush" Color="#FF1F2937" />
    <SolidColorBrush x:Key="ChatMutedBrush" Color="#FF667085" />
    <SolidColorBrush x:Key="ChatOwnMessageBrush" Color="#FF1877F2" />
    <SolidColorBrush x:Key="ChatOwnMessageBorderBrush" Color="#FF0C5DC7" />
    <SolidColorBrush x:Key="ChatOwnMessageForegroundBrush" Color="#FFF9FEFE" />
    <SolidColorBrush x:Key="ChatIncomingMessageBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="ChatIncomingMessageBorderBrush" Color="#FFD4E0E6" />

    <!--  Text  -->
    <Style
        x:Key="ChatHeadlineTextStyle"
        BasedOn="{StaticResource MaterialDesignHeadline4TextBlock}"
        TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Bahnschrift SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource ChatInkBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Margin" Value="0,0,0,16" />
    </Style>

    <Style
        x:Key="ChatTitleTextStyle"
        BasedOn="{StaticResource MaterialDesignHeadline6TextBlock}"
        TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Bahnschrift SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource ChatInkBrush}" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style
        x:Key="ChatSubtitleTextStyle"
        BasedOn="{StaticResource MaterialDesignBody1TextBlock}"
        TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource ChatMutedBrush}" />
        <Setter Property="Margin" Value="0,0,0,18" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style
        x:Key="ChatBodyTextStyle"
        BasedOn="{StaticResource MaterialDesignBody1TextBlock}"
        TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource ChatInkBrush}" />
    </Style>

    <Style
        x:Key="ChatMetaTextStyle"
        BasedOn="{StaticResource MaterialDesignCaptionTextBlock}"
        TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource ChatMutedBrush}" />
    </Style>

    <Style x:Key="ChatInlineHyperlinkStyle" TargetType="Hyperlink">
        <Setter Property="Foreground" Value="{StaticResource ChatMutedBrush}" />
        <Setter Property="TextDecorations" Value="Underline" />
        <Setter Property="FontWeight" Value="Normal" />
    </Style>

    <Style
        x:Key="ChatErrorTextStyle"
        BasedOn="{StaticResource MaterialDesignBody2TextBlock}"
        TargetType="TextBlock">
        <Setter Property="Margin" Value="0,0,0,14" />
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignValidationErrorBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style
        x:Key="ChatSectionLabelTextStyle"
        BasedOn="{StaticResource MaterialDesignOverlineTextBlock}"
        TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource ChatMutedBrush}" />
    </Style>

    <Style
        x:Key="ChatAvatarTextStyle"
        BasedOn="{StaticResource MaterialDesignBody1TextBlock}"
        TargetType="TextBlock">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="Bahnschrift SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource ChatPrimaryDarkBrush}" />
    </Style>

    <Style
        x:Key="ChatMessageSenderTextStyle"
        BasedOn="{StaticResource MaterialDesignCaptionTextBlock}"
        TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource ChatMutedBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style
        x:Key="ChatMessageContentTextStyle"
        BasedOn="{StaticResource MaterialDesignBody1TextBlock}"
        TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource ChatInkBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="22" />
    </Style>

    <!--  Inputs  -->
    <Style
        x:Key="ChatOutlinedTextBoxStyle"
        BasedOn="{StaticResource MaterialDesignOutlinedTextBox}"
        TargetType="TextBox">
        <Setter Property="Margin" Value="0,0,0,16" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="materialDesign:HintAssist.FloatingOffset" Value="0,-16" />
        <Setter Property="materialDesign:TextFieldAssist.LeadingIconSize" Value="20" />
    </Style>

    <Style
        x:Key="ChatOutlinedPasswordBoxStyle"
        BasedOn="{StaticResource MaterialDesignOutlinedPasswordBox}"
        TargetType="PasswordBox">
        <Setter Property="Margin" Value="0,0,0,16" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="materialDesign:HintAssist.FloatingOffset" Value="0,-16" />
        <Setter Property="materialDesign:TextFieldAssist.LeadingIconSize" Value="20" />
    </Style>

    <!--  Buttons  -->
    <Style
        x:Key="ChatPrimaryButtonStyle"
        BasedOn="{StaticResource MaterialDesignRaisedButton}"
        TargetType="Button">
        <Setter Property="Height" Value="46" />
        <Setter Property="Padding" Value="20,0" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Background" Value="{StaticResource ChatPrimaryBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="{StaticResource ChatCornerRadius}" />
    </Style>

    <Style
        x:Key="ChatSecondaryButtonStyle"
        BasedOn="{StaticResource MaterialDesignOutlinedButton}"
        TargetType="Button">
        <Setter Property="Height" Value="40" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="Margin" Value="0,0,10,0" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="BorderBrush" Value="{StaticResource ChatBorderStrongBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ChatInkBrush}" />
        <Setter Property="Background" Value="{StaticResource ChatPanelBrush}" />
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="{StaticResource ChatCornerRadius}" />
    </Style>

    <Style
        x:Key="ChatTextButtonStyle"
        BasedOn="{StaticResource MaterialDesignFlatButton}"
        TargetType="Button">
        <Setter Property="Height" Value="38" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource ChatPrimaryDarkBrush}" />
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="{StaticResource ChatCornerRadius}" />
    </Style>

    <Style
        x:Key="ChatMenuActionButtonStyle"
        BasedOn="{StaticResource MaterialDesignFlatButton}"
        TargetType="Button">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="Margin" Value="0,2,0,0" />
        <Setter Property="Foreground" Value="{StaticResource ChatInkBrush}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="{StaticResource ChatCornerRadius}" />
    </Style>

    <Style
        x:Key="ChatIconButtonStyle"
        BasedOn="{StaticResource MaterialDesignIconButton}"
        TargetType="Button">
        <Setter Property="Width" Value="42" />
        <Setter Property="Height" Value="42" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="Background" Value="{StaticResource ChatPanelAltBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ChatBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource ChatInkBrush}" />
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="{StaticResource ChatCornerRadius}" />
    </Style>

    <!--  Round primary action button (e.g. "start new conversation").  -->
    <Style
        x:Key="ChatFabButtonStyle"
        BasedOn="{StaticResource MaterialDesignIconButton}"
        TargetType="Button">
        <Setter Property="Width" Value="44" />
        <Setter Property="Height" Value="44" />
        <Setter Property="Background" Value="{StaticResource ChatPrimaryBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="22" />
        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp2" />
    </Style>

    <!--  Surfaces  -->
    <Style x:Key="ChatDialogCardStyle" TargetType="materialDesign:Card">
        <Setter Property="Padding" Value="{StaticResource ChatCardPadding}" />
        <Setter Property="Width" Value="{StaticResource ChatDialogWidth}" />
        <Setter Property="UniformCornerRadius" Value="6" />
        <Setter Property="Background" Value="{StaticResource ChatPanelBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ChatBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp12" />
    </Style>

    <!--  Panel used for every content block within a page (header bar, list, input bar, ...).  -->
    <Style x:Key="ChatSurfaceBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ChatPanelBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ChatBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource ChatCornerRadius}" />
        <Setter Property="Padding" Value="24" />
    </Style>

    <!--  Popover surface (e.g. the user menu).  -->
    <Style x:Key="ChatPopupSurfaceBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ChatPanelBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ChatBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource ChatCornerRadius}" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <!--  Highlighted callout panel (e.g. "selected user" confirmation).  -->
    <Style x:Key="ChatCalloutBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ChatPrimarySoftBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource ChatCornerRadius}" />
        <Setter Property="Padding" Value="12" />
    </Style>

    <!--  Avatar used everywhere a user is represented by their initial.  -->
    <Style x:Key="ChatAvatarBorderStyle" TargetType="Border">
        <Setter Property="Width" Value="{StaticResource ChatAvatarSize}" />
        <Setter Property="Height" Value="{StaticResource ChatAvatarSize}" />
        <Setter Property="Background" Value="{StaticResource ChatPrimarySoftBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource ChatCornerRadius}" />
    </Style>

    <!--  Row container in a list of entries (conversations, search results, ...).  -->
    <Style x:Key="ChatListItemBorderStyle" TargetType="Border">
        <Setter Property="Padding" Value="18" />
        <Setter Property="Background" Value="{StaticResource ChatPanelAltBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ChatBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource ChatCornerRadius}" />
    </Style>

    <!--  Small solid counter badge (e.g. unread count).  -->
    <Style x:Key="ChatCountBadgeBorderStyle" TargetType="Border">
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="Background" Value="{StaticResource ChatPrimaryBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource ChatCornerRadius}" />
    </Style>

    <!--  Small outlined info chip (e.g. message count).  -->
    <Style x:Key="ChatInfoChipBorderStyle" TargetType="Border">
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="Background" Value="{StaticResource ChatPanelStrongBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ChatBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource ChatCornerRadius}" />
    </Style>

    <!--  Chat message bubble.  -->
    <Style x:Key="ChatMessageBubbleBorderStyle" TargetType="Border">
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="Background" Value="{StaticResource ChatIncomingMessageBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ChatIncomingMessageBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource ChatCornerRadius}" />
    </Style>

    <!--  Lists  -->
    <Style
        x:Key="ChatMessageListStyle"
        BasedOn="{StaticResource MaterialDesignListBox}"
        TargetType="ListBox">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
    </Style>

    <Style
        x:Key="ChatConversationListStyle"
        BasedOn="{StaticResource MaterialDesignListBox}"
        TargetType="ListBox">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style
        x:Key="ChatConversationListItemStyle"
        BasedOn="{StaticResource MaterialDesignListBoxItem}"
        TargetType="ListBoxItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
</ResourceDictionary>
