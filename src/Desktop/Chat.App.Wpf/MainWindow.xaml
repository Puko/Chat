<Window
    x:Class="Chat.App.Wpf.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:loc="clr-namespace:Chat.App.Wpf.Localization"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:Chat.App.Wpf.ViewModels"
    Title="Chat"
    Width="1240"
    Height="820"
    MinWidth="480"
    MinHeight="540"
    d:DataContext="{d:DesignInstance Type=viewModels:MainWindowViewModel,
                                     IsDesignTimeCreatable=False}"
    Background="{StaticResource ChatWindowBackgroundBrush}"
    FontFamily="{materialDesign:MaterialDesignFont}"
    Style="{StaticResource MaterialDesignWindow}"
    TextElement.FontSize="14"
    TextElement.FontWeight="Regular"
    TextElement.Foreground="{DynamicResource MaterialDesignBody}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <materialDesign:DialogHost Identifier="RootDialog">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="8,8,8,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Button
                        Command="{Binding SetLanguageCommand}"
                        CommandParameter="sk"
                        Content="SK"
                        Style="{StaticResource ChatTextButtonStyle}" />
                    <Button
                        Command="{Binding SetLanguageCommand}"
                        CommandParameter="en"
                        Content="EN"
                        Style="{StaticResource ChatTextButtonStyle}" />
                </StackPanel>

                <materialDesign:PopupBox
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    PlacementMode="BottomAndAlignRightEdges"
                    StaysOpen="False"
                    Visibility="{Binding ShowUserMenu, Converter={StaticResource BooleanToVisibility}}">
                    <materialDesign:PopupBox.ToggleContent>
                        <Border Style="{StaticResource ChatAvatarBorderStyle}">
                            <TextBlock Style="{StaticResource ChatAvatarTextStyle}" Text="{Binding LoggedInUserInitial}" />
                        </Border>
                    </materialDesign:PopupBox.ToggleContent>

                    <Border MinWidth="220" Style="{StaticResource ChatPopupSurfaceBorderStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource ChatMetaTextStyle}" Text="{loc:Loc Shell_LoggedInUser}" />
                            <TextBlock
                                Margin="0,4,0,8"
                                Style="{StaticResource ChatBodyTextStyle}"
                                Text="{Binding LoggedInUsername}" />
                            <Button
                                Command="{Binding OpenNewConversationCommand}"
                                Content="{loc:Loc Shell_NewConversation}"
                                Style="{StaticResource ChatMenuActionButtonStyle}" />
                            <Button
                                Command="{Binding LogoutCommand}"
                                Content="{loc:Loc Shell_Logout}"
                                Style="{StaticResource ChatMenuActionButtonStyle}" />
                        </StackPanel>
                    </Border>
                </materialDesign:PopupBox>
            </Grid>

            <ContentControl x:Name="CurrentViewHost" Grid.Row="1" />
        </Grid>
    </materialDesign:DialogHost>
</Window>
